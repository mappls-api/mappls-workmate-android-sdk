<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="3dp"
        android:elevation="3dp"
        app:cardCornerRadius="5dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:id="@+id/count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/address"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawablePadding="10dp"
                android:drawableTint="@color/color_btn_back_dark"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="address"
                app:drawableStartCompat="@drawable/baseline_home_24" />

            <TextView
                android:id="@+id/lat_lng"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawablePadding="10dp"
                android:drawableTint="@color/color_btn_back_dark"
                android:text="lat and lng"
                app:drawableStartCompat="@drawable/baseline_location_pin_24" />

            <TextView
                android:id="@+id/speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawablePadding="10dp"
                android:drawableTint="@color/color_btn_back_dark"
                android:text="lat and lng"
                app:drawableStartCompat="@drawable/baseline_speed_24" />

            <TextView
                android:id="@+id/trail_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawablePadding="10dp"
                android:drawableTint="@color/color_btn_back_dark"
                android:text="lat and lng"
                app:drawableStartCompat="@drawable/baseline_access_time_24" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>